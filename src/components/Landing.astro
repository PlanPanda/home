    <div class="grid md:grid-cols-4 gap-12 mb-20">
      <div>
        <div class="flex items-center gap-2 mb-6">
          <img
            src="/favicon/web-app-manifest-512x512.png"
            alt="Solid Plan"
            width="24"
            height="24"
            class="rounded-md"
          />
          <span class="text-lg font-bold tracking-tight">Solid Plan</span>
        </div>
        <p class="text-sm text-muted leading-relaxed">
          เครื่องมือจัดการงานขายและทีมงาน
          <br />สำหรับตัวแทนประกันยุคใหม่
        </p>
      </div>
      <div>
        <h5
          class="font-bold text-xs tracking-[0.15em] uppercase text-muted-soft mb-4"
        >
          สินค้า
        </h5>
        <ul class="space-y-3 text-sm font-medium list-none p-0 m-0">
          <li>
            <a
              href="#features"
              class="text-ink no-underline hover:opacity-70 transition"
              >ฟีเจอร์</a
            >
          </li>
          <li>
            <a
              href="#pricing"
              class="text-ink no-underline hover:opacity-70 transition">ราคา</a
            >
          </li>
          <li>
            <a
              href="#showcase"
              class="text-ink no-underline hover:opacity-70 transition"
              >iPad App</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >Roadmap</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h5
          class="font-bold text-xs tracking-[0.15em] uppercase text-muted-soft mb-4"
        >
          บริษัท
        </h5>
        <ul class="space-y-3 text-sm font-medium list-none p-0 m-0">
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >เกี่ยวกับเรา</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >ร่วมงานกับเรา</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >นโยบายความเป็นส่วนตัว</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h5
          class="font-bold text-xs tracking-[0.15em] uppercase text-muted-soft mb-4"
        >
          ช่วยเหลือ
        </h5>
        <ul class="space-y-3 text-sm font-medium list-none p-0 m-0">
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >ศูนย์ช่วยเหลือ</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >คู่มือการใช้งาน</a
            >
          </li>
          <li>
            <a
              href="#"
              class="text-ink no-underline hover:opacity-70 transition"
              >ติดต่อเรา</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div
      class="pt-8 border-t border-black/5 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-muted-soft font-medium"
    >
      <p>&copy; 2024 Solid Plan. รายได้ที่ดี มาจากระบบ.</p>
      <div class="flex gap-6">
        <a href="#" class="no-underline hover:opacity-70 transition">Facebook</a
        >
        <a href="#" class="no-underline hover:opacity-70 transition">Line OA</a>
      </div>
    </div>
  </div>
</footer>

<!-- ===== MOBILE MENU SCRIPT ===== -->
<script>
  const toggle = document.getElementById("menuToggle");
  const menu = document.getElementById("mobileMenu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      menu.classList.toggle("hidden");
      menu.classList.toggle("flex");
    });
    menu.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        menu.classList.add("hidden");
        menu.classList.remove("flex");
      }),
    );
  }
</script>
